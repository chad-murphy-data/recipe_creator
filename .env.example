# Copy this file to .env (which is gitignored).

# --- Client values (shipped to the browser; safe by design) ---
# Use the PUBLISHABLE key here (sb_publishable_...), NOT a secret key.
# - publishable / anon: safe in the browser; access is governed by row-level
#   security, not by hiding the key.
# - secret (sb_secret_...) or legacy service_role: NEVER put these in the
#   browser. Supabase hard-blocks them client-side ("Forbidden use of secret
#   API key in browser") and they bypass RLS entirely. The sb_publishable_ and
#   sb_secret_ prefixes look almost identical, so copy carefully.
VITE_SUPABASE_URL=https://nwgxyytowbluuykbdcfc.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_MF7iftdZykPrfelnVnJHew_DSuyVLJ1

# --- Server-only values (NEVER shipped to the browser; no VITE_ prefix) ---
# Used by the Vite dev proxy (npm run dev) and the Netlify function. In
# production set these in the Netlify UI under Site settings > Environment
# variables, not here.

# Powers the recipe engine (Generator + judge).
ANTHROPIC_API_KEY=

# Shared password that gates the app. Set it to turn the lock screen on; leave
# it blank to run with no gate. Checked server-side, so it is a real gate on the
# Anthropic calls, not just a hidden screen.
APP_PASSWORD=
